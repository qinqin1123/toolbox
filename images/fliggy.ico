            var reg = new RegExp(t.referRegExp, "i");
            if ((t.env === 'mobile' && isMobile && reg.test(refUrl)) || (t.env === 'pc' && !isMobile && reg.test(refUrl))) {
              fromSE = true;
              ttid = t.ttid;
            }
          }
        }

        if (fromSE) {
          var needRep = false;
          if (ttid && href.indexOf('ttid') < 0) {
            href = addUrlParams(href, { ttid: ttid, seoType: 'origin' });
            needRep = true;
          }
          if (isMobile &&
            new RegExp("^(www.fliggy.com|www.alitrip.com|btrip.alitrip.com)$").test(location.host) &&
            new RegExp("^/?$").test(location.pathname)
          ) {
            href = 'https://m.fliggy.com?ttid=' + ttid + '&seoType=origin';
            needRep = true;
          } else if (!!location.href.match(new RegExp("www.fliggy.com/travel/detail-(d+)")) && !/id=d+/.test(location.search)) {
            var currentId = location.href.match(new RegExp("www.fliggy.com/travel/detail-(d+)"))[1];
            href = addUrlParams(href, { id: currentId });
            needRep = true;
          }
          needRep && window.location.replace(href);
          return;
        }
        if (isMobile &&
          new RegExp("^(pre-www.fliggy.com|www.fliggy.com|www.alitrip.com|btrip.alitrip.com)$").test(location.host) &&
          new RegExp("^/?$").test(location.pathname)
        ) {
          href = 'https://market.m.taobao.com/app/trip/rx-home/pages/home';
          window.location.replace(href);
          return;
        }
        if (isMobile &&
          new RegExp("^market.(m|wapa).taobao.com$").test(location.host) &&
          new RegExp("^/app/trip/h5-lazada-pc-fliggy-home-ssr/pages/home").test(location.pathname)
        ) {
