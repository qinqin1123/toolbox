<script>
var resumeSummary = ''
function renderLevel () {
getScore()
function getScore () {
$.ajax({
type:'get',
url: getHost().newApiHost + '/api/resume/v2.0/resume/summary',
xhrFields: {
withCredentials: true // 发送Ajax时，Request header中会带上 Cookie 信息。
},
success: function (r) {
var d = JSON.parse(r)
if(d.code== 100) {
resumeSummary = d.msg
if (d.msg.online.length) {
// 获取分数
$.ajax({
type: 'get',
url: getHost().newApiHost + '/api/resume/v2.0/resume/detail',
xhrFields: {
withCredentials: true // 发送Ajax时，Request header中会带上 Cookie 信息。
},
data: {
guuid: d.msg.online[0].guuid,
lan: 'chinese'
},
success: function(j) {
var res = JSON.parse(j)
$('#myResume').html('我的简历 ('+res.msg.score+'%)')
if (res.code == 100) {
$.ajax({
type: 'get',
url: getHost().newApiHost + '/api/resume/v2.0/completion',
xhrFields: {
withCredentials: true // 发送Ajax时，Request header中会带上 Cookie 信息。
},
success: function(ii) {
var i = JSON.parse(ii)
if (!i.msg.canDelivered) {
if (window.location.pathname !== '/cheerstation') {
if (res.msg.score || res.msg.score == 0) {
render(res.msg.score)
}
}
// 侧边栏显示分数
if (res.msg.score || res.msg.score == 0) {
$('.resume_img').append('<div class="resume_text">'+res.msg.score+'%</div>')
}
} else {
$('#resume').addClass('delivered')
$('#right-resume-icon').attr('src', "https://sxsimg.xiaoyuanzhao.com/static/new_main/img/right-resume-default.png?v=b0249f1d8d38e166b86e38a4df0d522f")
}
}
})
}
}
})
}
}
}
})
}
function render (score) {
var levelText = ''
var level = getLevel(score)
var rank = ''
var star1 = "https://sxsimg.xiaoyuanzhao.com/static/new_main/img/icon_star1.png?v=c8c78a12d4b42c57acad32bfcc489c24"
var star2 = "https://sxsimg.xiaoyuanzhao.com/static/new_main/img/icon_star2.png?v=dbfcbff598230e5edb5a7b84b6f9ccdc"
var closeImg = "https://sxsimg.xiaoyuanzhao.com/static/new_main/img/icon_close.png?v=b771dd317e0fcfff45007241e1ee6c87"
var star1_img = ''
for (var i = 0; i < Math.floor(level); i++) {
star1_img += '<img src="'+star1+'" />'
}
var star2_img = '<img src="'+star2+'" alt="">'
if (level > Math.floor(level)) {
rank += '<div class="rank">'+ star1_img + star2_img + '</div>'
}
if (level == Math.floor(level)) {
rank += '<div class="rank">\
' + star1_img +'\
</div>'
}
var renderR = ''
if (level) {
renderR += '<div class="label">简历评级：</div>'+rank
}
var str = '<div class="rank-pannel">\
'+renderR+'<div class="text" onclick="goToResume()">'+levelText+'>></div>\
<div class="close" onclick="closeLevel()"><img src="'+closeImg+'"/>\
</div>\
</div>'

if (level >= 0) {
$('.header').append('<div class="resume-level">' + str + '</div>')
}

function getLevel (score) {
if (!score) {
levelText = '刚刚有HR看了看你，发现没简历走了，快完善简历吧骚年~'
return 0
} else {
if (score > 0 && score <= 20) {
levelText = '尽早完善简历，提前进入企业人才库，抢占先机，毕业时高薪机会主动找上门~'
} else if (score > 20 && score <= 40) {
levelText = '简历分数低于全国80%的学生，多花几分钟时间，超越他们吧~'
} else if (score > 40 && score <= 60) {
levelText = '再多填几项就能获取企业关注哦，加把劲儿！！！'
} else if (score > 60 && score <= 80) {
levelText = '简历已经及格了哟~可以继续优化'
} else if (score > 80 && score < 100) {
levelText = '简历已超过了80%的用户，再努力一把，让自己脱颖而出吧！'
} else if (score === 100) {
levelText = '恭喜！您的简历相当完整，快去投递吧！'
}
return score / 20
}
}
}
}
function getHost() {
var hostPrefix = location.host.split('.')[0]
switch (hostPrefix) {
case 'localhost:8700':
return {
frontendHost: 'http://sit1-sxs-frontend.mshare.cn',
mainsite: 'http://sit1-sxs-web.mshare.cn',
frontend: 'http://sit1-sxs-frontend.mshare.cn',
newApiHost: 'http://istio-test-apigateway.mshare.cn',
optionHost: 'http://sit1-ad-service.mshare.cn',
hrFrontendHost: 'http://sit1-hr-frontend.mshare.cn'
}
case 'www':
case 'tv':
case 'resume':
case 'wap':
case 'tuiguang':
return {
frontendHost: 'https://resume.shixiseng.com',
mainsite: 'https://www.shixiseng.com',
frontend: 'https://resume.shixiseng.com',
newApiHost: 'https://apigateway.shixiseng.com',
optionHost: 'https://operation.shixiseng.com',
hrFrontendHost: 'https://hr.shixiseng.com'
}
case 'wwwnew':
case 'resumenew':
return {
frontendHost: 'https://resumenew.shixiseng.com',
mainsite: 'https://wwwnew.shixiseng.com',
frontend: 'https://resumenew.shixiseng.com',
newApiHost: 'https://apigateway.shixiseng.com',
optionHost: 'https://operation.shixiseng.com',
hrFrontendHost: 'https://hr.shixiseng.com'
}
case 'dev':
return {
frontendHost: 'http://sit1-local.mshare.cn',
mainsite: 'http://sit1-sxs-web.mshare.cn',
frontend: 'http://sit1-sxs-frontend.mshare.cn',
newApiHost: 'http://istio-dev-apigateway.mshare.cn',
optionHost: 'http://sit1-ad-service.mshare.cn',
hrFrontendHost: 'http://sit1-hr-frontend.mshare.cn'
}
default:
var env = hostPrefix.split('-')[0]
var istioEnv
if (env !== 'dev' && env !== 'uat') {
istioEnv = 'test'
} else {
istioEnv = env
}
return {
frontendHost: 'http://sit1-sxs-frontend.mshare.cn',
hrFrontendHost: 'http://sit1-hr-frontend.mshare.cn',
mainsite: 'http://' + env + '-sxs-web.mshare.cn',
frontend: 'http://' + env + '-sxs-frontend.mshare.cn',
newApiHost: 'http://istio-' + istioEnv +'-apigateway.mshare.cn',
optionHost: 'http://' + env + '-ad-service.mshare.cn'
}
}
}
function goToResume () {
var host = getHost()
if (resumeSummary.online && resumeSummary.online[0]) {
window.open(host.frontendHost + '/resume/' + resumeSummary.online[0].guuid + '?lan=chinese&scroll=1')
}
}
function closeLevel () {
$('.resume-level').remove()
}

function rightToResume () {
var host = getHost()


window.open('/user/login?resume=1')

}
// 渲染广告
var adBottom = '10px'

adBottom = getCookie('bottom_banner') ? '10px' : '134px'

var _adRender = new RenderAd({
bottom: adBottom
});
window.footerLogin = new MxCommonComp.FooterLogin({
hide: function() {
_adRender.changeStyle({
bottom: '10px'
})
}
})
window.loginDialog = new MxCommonComp.LoginDialog({
loginSuccessCallBack: loginSuccessCallBack,
guideType: 1
})
$('.message-btn').on('click', function() {

$('.message-modal').show()
document.body.style.overflow = 'hidden';
document.body.style.position = 'fixed';

})
$('.message-modal .close').on('click', function() {
$('.message-modal').hide()
document.body.style.overflow = 'auto';
document.body.style.position = 'static';
})
$('.message-modal').on('click', function(e) {
$('.message-modal').hide()
document.body.style.overflow = 'auto';
document.body.style.position = 'static';
})
$('.message-modal .pannel').click(function(e) {e.stopPropagation()})
function loginSuccessCallBack (callback) {
window.xMethod.sendData({
event_type: 'IStudents Label',
event_id: 'web_1000057'
})
$('.modal').show()
var choiseVal
$('.modal .choise .choise-item input').on('change', function() {
choiseVal = $(this).val()
if (choiseVal == '1') {
window.xMethod.sendData({
event_type: 'IStudents Label',
event_id: 'web_1000058'
})
} else if (choiseVal == '0') {
window.xMethod.sendData({
event_type: 'IStudents Label',
event_id: 'web_1000059'
})
}
$('.modal .btn').addClass('active')
$(this).parent('.choise-item').siblings().removeClass('active')
$(this).parent('.choise-item').addClass('active')
})
$('.modal .btn').on('click', function() {
if (choiseVal == '0' || choiseVal == '1') {
window.xMethod.sendData({
event_type: 'IStudents Label',
event_id: 'web_1000060'
})
$.ajax({
type:'post',
url: getHost().newApiHost + '/api/account/v3.0/study/abraod',
xhrFields: {
withCredentials: true // 发送Ajax时，Request header中会带上 Cookie 信息。
},
data: {'oversea': parseInt(choiseVal)},
success: function (r) {
var json = JSON.parse(r)
if (json.code == 100) {
$('.modal').hide()
callback && callback()
} else {
new MxCommonComp.showAlert({
type: 'error',
message: json.msg
})
}
}
})
}
})
}
function getSummary(callback) {
if (resumeSummary && resumeSummary.online) {
if (resumeSummary.online[0]) {
var url = getHost().frontendHost + '/resume/' + resumeSummary.online[0].guuid + '?lan=chinese'
callback && callback(url)
} else {
var url = getHost().frontendHost + '/personal-center'
callback && callback(url)
}
} else {
$.ajax({
type:'get',
url: getHost().newApiHost + '/api/resume/v2.0/resume/summary',
xhrFields: {
withCredentials: true // 发送Ajax时，Request header中会带上 Cookie 信息。
},
success: function (r) {
var resumeSummary = JSON.parse(r).msg
if (resumeSummary.online) {
if (resumeSummary.online[0]) {
var url = getHost().frontendHost + '/resume/' + resumeSummary.online[0].guuid + '?lan=chinese'
callback && callback(url)
} else {
var url = getHost().frontendHost + '/personal-center'
callback && callback(url)
}
}
}
})
}
}
</script>
