nt-normal text-[#282828]" style="left:54.54545454545454%">2020</div><div class="absolute -translate-x-1/2 text-center text-[14px] font-normal text-[#282828]" style="left:63.63636363636363%">2019</div><div class="absolute -translate-x-1/2 text-center text-[14px] font-normal text-[#282828]" style="left:72.72727272727273%">2018</div><div class="absolute -translate-x-1/2 text-center text-[14px] font-normal text-[#282828]" style="left:81.81818181818183%">2017</div><div class="absolute -translate-x-1/2 text-center text-[14px] font-normal text-[#282828]" style="left:90.9090909090909%">2016</div><div class="absolute -translate-x-1/2 text-center text-[14px] font-normal text-[#282828]" style="left:100%">2015</div></div></div></section><section class="milestone relative block w-full px-[24px] md:hidden"><div class="title whitespace-pre-wrap pt-[90px] text-center text-[24px] font-extrabold text-s02">Soul的发展历程</div><div class="relative mb-[36px] mt-[29px] flex"><div class="absolute left-0 top-[8px] h-full w-[14px]"><svg width="14" height="100%" xmlns="http://www.w3.org/2000/svg" style="display:block"><defs><pattern id="timeline-pattern" x="0" y="0" width="14" height="3.5" patternUnits="userSpaceOnUse"><rect x="0" y="0" width="14" height="1.5" fill="rgba(71,71,71,0.12)"></rect></pattern></defs><rect width="100%" height="100%" fill="url(#timeline-pattern)"></rect></svg></div><div class="relative z-10 flex flex-1 flex-col pl-[54px]"><div class="jsx-71cbe7ba4c9537e2 milestone-item-mobile relative mb-[32px] flex flex-col"><div class="jsx-71cbe7ba4c9537e2 flex flex-col"><div class="jsx-71cbe7ba4c9537e2 relative size-[16px] shrink-0"><img alt="star" loading="lazy" width="16" height="16" decoding="async" data-nimg="1" class="block" style="color:transparent" srcSet="/_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ficon-star.78fa110c.png&amp;w=16&amp;q=75 1x, /_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ficon-star.78fa110c.png&amp;w=32&amp;q=75 2x" src="/_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ficon-star.78fa110c.png&amp;w=32&amp;q=75"/></div><p class="jsx-71cbe7ba4c9537e2 mt-[4px] text-[14px] font-semibold leading-normal text-[#282828]">2026年</p></div><div class="jsx-71cbe7ba4c9537e2 mt-[4px] w-full min-w-[255px]"><p class="jsx-71cbe7ba4c9537e2 text-[13px] font-light leading-normal text-[#65687A]">先后开源实时数字人生成模型SoulX-FlashTalk（14B）、歌声合成模型 SoulX-Singer、实时数字人生成模型SoulX-FlashHead（1.3B），将多项能力推进到可规模商用阶段。</p></div></div><div class="jsx-71cbe7ba4c9537e2 milestone-item-mobile relative mb-[32px] flex flex-col"><div class="jsx-71cbe7ba4c9537e2 flex flex-col"><div class="jsx-71cbe7ba4c9537e2 relative size-[16px] shrink-0"><img alt="star" loading="lazy" width="16" height="16" decoding="async" data-nimg="1" class="block" style="color:transparent" srcSet="/_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ficon-star.78fa110c.png&amp;w=16&amp;q=75 1x, /_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ficon-star.78fa110c.png&amp;w=32&amp;q=75 2x" src="/_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ficon-star.78fa110c.png&amp;w=32&amp;q=75"/></div><p class="jsx-71cbe7ba4c9537e2 mt-[4px] text-[14px] font-semibold leading-normal text-[#282828]">2025年</p></div><div class="jsx-71cbe7ba4c9537e2 mt-[4px] w-full min-w-[255px]"><p class="jsx-71cbe7ba4c9537e2 text-[13px] font-light leading-normal text-[#65687A]">我们引入“情价比消费”概念，“原生情绪价值第一大模型”Soul X能力持续提升，拓展“情绪绿洲”价值。</p></div></div><div class="jsx-71cbe7ba4c9537e2 milestone-item-mobile relative mb-[32px] flex flex-col"><div class="jsx-71cbe7ba4c9537e2 flex flex-col"><div class="jsx-71cbe7ba4c9537e2 relative size-[16px] shrink-0"><img alt="star" loading="lazy" width="16" height="16" decoding="async" data-nimg="1" class="block" style="color:transparent" srcSet="/_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ficon-star.78fa110c.png&amp;w=16&amp;q=75 1x, /_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ficon-star.78fa110c.png&amp;w=32&amp;q=75 2x" src="/_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ficon-star.78fa110c.png&amp;w=32&amp;q=75"/></div><p class="jsx-71cbe7ba4c9537e2 mt-[4px] text-[14px] font-semibold leading-normal text-[#282828]">2024年</p></div><div class="jsx-71cbe7ba4c9537e2 mt-[4px] w-full min-w-[255px]"><p class="jsx-71cbe7ba4c9537e2 text-[13px] font-light leading-normal text-[#65687A]">我们确立“模应一体”的发展战略，同步探索大模型开发与平台内多元场景应用落地。</p></div></div><div class="jsx-71cbe7ba4c9537e2 milestone-item-mobile relative mb-[32px] flex flex-col"><div class="jsx-71cbe7ba4c9537e2 flex flex-col"><div class="jsx-71cbe7ba4c9537e2 relative size-[16px] shrink-0"><img alt="star" loading="lazy" width="16" height="16" decoding="async" data-nimg="1" class="block" style="color:transparent" srcSet="/_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ficon-star.78fa110c.png&amp;w=16&amp;q=75 1x, /_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ficon-star.78fa110c.png&amp;w=32&amp;q=75 2x" src="/_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ficon-star.78fa110c.png&amp;w=32&amp;q=75"/></div><p class="jsx-71cbe7ba4c9537e2 mt-[4px] text-[14px] font-semibold leading-normal text-[#282828]">2023年</p></div><div class="jsx-71cbe7ba4c9537e2 mt-[4px] w-full min-w-[255px]"><p class="jsx-71cbe7ba4c9537e2 text-[13px] font-light leading-normal text-[#65687A]">我们推出自研“原生情绪价值第一大模型”Soul X，入选《2023胡润全球独角兽榜》。</p></div></div><div class="jsx-71cbe7ba4c9537e2 milestone-item-mobile relative mb-[32px] flex flex-col"><div class="jsx-71cbe7ba4c9537e2 flex flex-col"><div class="jsx-71cbe7ba4c9537e2 relative size-[16px] shrink-0"><img alt="star" loading="lazy" width="16" height="16" decoding="async" data-nimg="1" class="block" style="color:transparent" srcSet="/_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ficon-star.78fa110c.png&amp;w=16&amp;q=75 1x, /_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ficon-star.78fa110c.png&amp;w=32&amp;q=75 2x" src="/_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ficon-star.78fa110c.png&amp;w=32&amp;q=75"/></div><p class="jsx-71cbe7ba4c9537e2 mt-[4px] text-[14px] font-semibold leading-normal text-[#282828]">2022年</p></div><div class="jsx-71cbe7ba4c9537e2 mt-[4px] w-full min-w-[255px]"><p class="jsx-71cbe7ba4c9537e2 text-[13px] font-light leading-normal text-[#65687A]">我们在移动应用程序中引入音乐房间功能（包括K歌房间及一起听歌），并正式推出Nawa引擎。</p></div></div><div class="jsx-71cbe7ba4c9537e2 milestone-item-mobile relative mb-[32px] flex flex-col"><div class="jsx-71cbe7ba4c9537e2 flex flex-col"><div class="jsx-71cbe7ba4c9537e2 relative size-[16px] shrink-0"><img alt="star" loading="lazy" width="16" height="16" decoding="async" data-nimg="1" class="block" style="color:transparent" srcSet="/_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ficon-star.78fa110c.png&amp;w=16&amp;q=75 1x, /_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ficon-star.78fa110c.png&amp;w=32&amp;q=75 2x" src="/_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ficon-star.78fa110c.png&amp;w=32&amp;q=75"/></div><p class="jsx-71cbe7ba4c9537e2 mt-[4px] text-[14px] font-semibold leading-normal text-[#282828]">2021年</p></div><div class="jsx-71cbe7ba4c9537e2 mt-[4px] w-full min-w-[255px]"><p class="jsx-71cbe7ba4c9537e2 text-[13px] font-light leading-normal text-[#65687A]">我们引入3D Avatar，日活跃用户数超过1千万人。</p></div></div><div class="jsx-71cbe7ba4c9537e2 milestone-item-mobile relative mb-[32px] flex flex-col"><div class="jsx-71cbe7ba4c9537e2 flex flex-col"><div class="jsx-71cbe7ba4c9537e2 relative size-[16px] shrink-0"><img alt="star" loading="lazy" width="16" height="16" decoding="async" data-nimg="1" class="block" style="color:transparent" srcSet="/_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ficon-star.78fa110c.png&amp;w=16&amp;q=75 1x, /_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ficon-star.78fa110c.png&amp;w=32&amp;q=75 2x" src="/_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ficon-star.78fa110c.png&amp;w=32&amp;q=75"/></div><p class="jsx-71cbe7ba4c9537e2 mt-[4px] text-[14px] font-semibold leading-normal text-[#282828]">2020年</p></div><div class="jsx-71cbe7ba4c9537e2 mt-[4px] w-full min-w-[255px]"><p class="jsx-71cbe7ba4c9537e2 text-[13px] font-light leading-normal text-[#65687A]">我们开始通过广告服务获利，并在移动应用程序中引入派对房间功能。</p></div></div><div class="jsx-71cbe7ba4c9537e2 milestone-item-mobile relative mb-[32px] flex flex-col"><div class="jsx-71cbe7ba4c9537e2 flex flex-col"><div class="jsx-71cbe7ba4c9537e2 relative size-[16px] shrink-0"><img alt="star" loading="lazy" width="16" height="16" decoding="async" data-nimg="1" class="block" style="color:transparent" srcSet="/_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ficon-star.78fa110c.png&amp;w=16&amp;q=75 1x, /_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ficon-star.78fa110c.png&amp;w=32&amp;q=75 2x" src="/_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ficon-star.78fa110c.png&amp;w=32&amp;q=75"/></div><p class="jsx-71cbe7ba4c9537e2 mt-[4px] text-[14px] font-semibold leading-normal text-[#282828]">2019年</p></div><div class="jsx-71cbe7ba4c9537e2 mt-[4px] w-full min-w-[255px]"><p class="jsx-71cbe7ba4c9537e2 text-[13px] font-light leading-normal text-[#65687A]">我们开始商业化。</p></div></div><div class="jsx-71cbe7ba4c9537e2 milestone-item-mobile relative mb-[32px] flex flex-col"><div class="jsx-71cbe7ba4c9537e2 flex flex-col"><div class="jsx-71cbe7ba4c9537e2 relative size-[16px] shrink-0"><img alt="star" loading="lazy" width="16" height="16" decoding="async" data-nimg="1" class="block" style="color:transparent" srcSet="/_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ficon-star.78fa110c.png&amp;w=16&amp;q=75 1x, /_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ficon-star.78fa110c.png&amp;w=32&amp;q=75 2x" src="/_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ficon-star.78fa110c.png&amp;w=32&amp;q=75"/></div><p class="jsx-71cbe7ba4c9537e2 mt-[4px] text-[14px] font-semibold leading-normal text-[#282828]">2018年</p></div><div class="jsx-71cbe7ba4c9537e2 mt-[4px] w-full min-w-[255px]"><p class="jsx-71cbe7ba4c9537e2 text-[13px] font-light leading-normal text-[#65687A]">Soul的日活跃用户数超过1百万人。</p></div></div><div class="jsx-71cbe7ba4c9537e2 milestone-item-mobile relative mb-[32px] flex flex-col"><div class="jsx-71cbe7ba4c9537e2 flex flex-col"><div class="jsx-71cbe7ba4c9537e2 relative size-[16px] shrink-0"><img alt="star" loading="lazy" width="16" height="16" decoding="async" data-nimg="1" class="block" style="color:transparent" srcSet="/_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ficon-star.78fa110c.png&amp;w=16&amp;q=75 1x, /_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ficon-star.78fa110c.png&amp;w=32&amp;q=75 2x" src="/_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ficon-star.78fa110c.png&amp;w=32&amp;q=75"/></div><p class="jsx-71cbe7ba4c9537e2 mt-[4px] text-[14px] font-semibold leading-normal text-[#282828]">2017年</p></div><div class="jsx-71cbe7ba4c9537e2 mt-[4px] w-full min-w-[255px]"><p class="jsx-71cbe7ba4c9537e2 text-[13px] font-light leading-normal text-[#65687A]">我们开发移动应用程序中的“星球”功能，并实施我们专有的推荐算法及先进的兴趣图谱描绘系统，使数据分析成为我们平台背后的驱动力。</p></div></div><div class="jsx-71cbe7ba4c9537e2 milestone-item-mobile relative mb-[32px] flex flex-col"><div class="jsx-71cbe7ba4c9537e2 flex flex-col"><div class="jsx-71cbe7ba4c9537e2 relative size-[16px] shrink-0"><img alt="star" loading="lazy" width="16" height="16" decoding="async" data-nimg="1" class="block" style="color:transparent" srcSet="/_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ficon-star.78fa110c.png&amp;w=16&amp;q=75 1x, /_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ficon-star.78fa110c.png&amp;w=32&amp;q=75 2x" src="/_next/image?url=%2F_next%2Fstatic%2Fmedia%2Ficon-star.78fa110c.png&amp;w=32&amp;q=75"/></div><p class="jsx-71cbe7ba4c9537e2 mt-[4px] text-[14px] font-semibold leading-normal text-[#282828]">2016年</p></div><div class="jsx-71cbe7ba4c9537e2 mt-[4px] w-full min-w-[255px]"><p class="jsx-71cbe7ba4c9537e2 text-[13px] font-light leading-normal text-[#65687A]">我们推出移动应用程序 — “Soul”。</p></div></div><div class="jsx-71cbe7ba4c9537e2 milestone-item-mobile relative mb-[32px] flex flex-col"><div class="jsx-71cbe7ba4c9537e2 flex flex-col"><div class="jsx-71cbe7ba4c9537e2 relative size-[16px] shrink-0"><img alt="star" loading="lazy" width="16" height="16" decoding="async" data-nimg="1" class="block" style="color:transparent" 